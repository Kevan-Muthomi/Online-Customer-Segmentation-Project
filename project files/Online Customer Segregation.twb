      <column caption='Loyal Count' datatype='real' name='[Calculation_1504765290170298369]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Segment]= &apos;Loyal Customers&apos; THEN [CustomerID] END' />
      </column>
      <column caption='Casual Count' datatype='real' name='[Calculation_1504765290170540034]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Segment] = &apos;Casual Customers&apos; THEN [CustomerID] END' />
